# Path to llama-server binary (or just the name if it's in $PATH)
METALLAMA_LLAMACPP_BINARY=/home/joz/Documents/AI-Tools/llama.cpp/build/bin/llama-server

# Directory for .gguf files (model picker & HF downloads)
